{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
        "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src"},
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}